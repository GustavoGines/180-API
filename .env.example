APP_NAME=180_API
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es_ES
APP_FAKER_LOCALE=es_ES

APP_TIMEZONE=America/Argentina/Buenos_Aires

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=180_pasteleria_api
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Cola de trabajos en background (notificaciones FCM, emails, etc.)
# Usar 'sync' en desarrollo local para ejecución inmediata sin worker
# Usar 'database' en producción (requiere php artisan queue:work)
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────
# Almacenamiento de archivos (Cloudflare R2 / AWS S3)
# ─────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
# Obligatorio para Cloudflare R2. Para AWS S3 estándar, dejar vacío.
AWS_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────────────────
# Google Calendar
# Obtener con: cat pasteleria-service-account.json | base64 -w 0
# ─────────────────────────────────────────────────────────────────────
GOOGLE_CALENDAR_ID=tu_calendario@group.calendar.google.com
GOOGLE_APP_CREDENTIALS_BASE64="... (service account JSON en base64, una sola línea)"

# ─────────────────────────────────────────────────────────────────────
# Firebase (FCM — notificaciones push)
# Obtener en: Firebase Console → Project Settings → Service Accounts
# ─────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=demo-project

# ─────────────────────────────────────────────────────────────────────
# Frontend / CORS
# URL del frontend Flutter compilado (web) o dominio del cliente
# ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000